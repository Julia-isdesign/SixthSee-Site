# isDesign.com.br
<IfModule mod_rewrite.c>
	RewriteEngine on
	Options +FollowSymlinks

	# HTTPS
	RewriteCond %{HTTPS} off 
	RewriteRule (.*) https://%{HTTP_HOST}%{REQUEST_URI} [R,L]

	# www
	rewritecond %{http_host} ^seecranes.ind.br [NC]
	rewriterule ^(.*)$ https://www.seecranes.ind.br/site/$1 [r=301,NC]

	# 404
	ErrorDocument 400 https://www.seecranes.ind.br/site/404
	ErrorDocument 403 https://www.seecranes.ind.br/site/404
	ErrorDocument 404 https://www.seecranes.ind.br/site/404

	# 404
	RewriteRule ^404/?$ 404.php [NC,L]

	# Produtos
	RewriteRule ^produtos/?$ produtos.php [NC,L]
	RewriteRule ^produtos/([0-9]+)/([a-z0-9-_]+)/?$ produtos.php?categoria=$1 [NC,L]
	RewriteRule ^produto/([0-9]+)/([a-z0-9-_]+)/?$ produtos-detalhes.php?id=$1 [NC,L]

	# P·ginas
	RewriteRule ^([a-z0-9-_]+)/?$ textos.php?url=$1 [NC,L]

</IfModule>

# CACHE
# Minuto: 60
# Hora: 3600
# Dia: 86400
# Semana: 604800
# Mes: 2628000
# Ano: 31536000
<IfModule mod_expires.c>

	# Um ano para arquivos
	<filesMatch ".(jpg|JPG|jpeg|JPEG|png|PNG|gif|GIF|ico|ICO|svg|SVG|webp|WEBP|eot|ETO|ttf|TTF|woff|WOFF|woff2|WOFF2|css|CSS|js|JS)$">
		Header set Cache-Control "max-age=31536000, public"
	</filesMatch>

	# Sem cache para HTML e PHP
	<FilesMatch "\.(htm|HTM|html|HTML|php|PHP)$">
		ExpiresByType text/html "now"
	</FilesMatch>

</IfModule>

# COMPACTACAO GZIP
<IfModule mod_gzip.c>

	mod_gzip_on Yes
	mod_gzip_dechunk Yes

	AddType image/svg+xml svg svgz
	AddEncoding gzip svgz

	mod_gzip_item_include file \.(html?|txt|css|js|min|php|pl|eot|ttf|woff|woff2|svg)$
	mod_gzip_item_include handler ^cgi-script$
	mod_gzip_item_include mime ^text/.*
	mod_gzip_item_include mime ^application/x-javascript.*
	mod_gzip_item_include mime ^image/.*
	mod_gzip_item_exclude rspheader ^Content-Encoding:.*gzip.*

</IfModule>